# LUMINA Ponder indexer — env vars (Sprint "Ponder revival").
# Copy to indexer/.env for local dev. In Railway, set these as SERVICE-level
# env vars on the same lumina-api service so the API and indexer share one
# source of truth. Code never hardcodes addresses — these env vars are required.

# ── RPC (priority: QuickNode > Alchemy > public) ──
# The indexer's eth_getLogs backfill is heavy; an archive endpoint is strongly
# preferred. Public sepolia.base.org works but is slow/rate-limited for backfill.
RPC_URL_QUICKNODE=https://YOUR-ENDPOINT.base-sepolia.quiknode.pro/YOUR_KEY/
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── Database ── Ponder needs Postgres. In Railway: add a Postgres plugin and
# paste its DATABASE_URL here (NEVER commit a real one). Do NOT reuse the
# API's SQLite (api/lumina.db).
DATABASE_URL=postgres://user:pass@host:port/lumina_indexer

# ── Canonical V5.4 contract addresses (Base Sepolia, 84532) ──
# These are PUBLIC on-chain addresses; safe as documented defaults. Verify
# against audit-pack manifest V5.4-canonical-deployed before mainnet.
COVER_ROUTER=0xcdB70B40e6a3DEac3189185d947A0e458518F566
CLAIM_BOND=0xaa57Ab52Eb00f296Ad4CFA9E9c201f3737271FB4
BOND_VAULT=0x193acBc1EdC5E565a4aBE96941C7E7AeF637B6EC
TWAP_BURNER=0x242d76082856901b4ba1E7c50C022D46a6941bC0
MARKETPLACE=0x0938205f4cBe5F572656533FC930FFce6F5F4345
# FounderVesting (immutable) — paste the full V5.4 address before enabling
# vesting indexing; leave blank to skip (handler simply never fires).
FOUNDER_VESTING=

# ── Indexer start block ── V5.4 genesis on Base Sepolia. Avoids scanning from
# chain genesis. Override only on a fresh redeploy.
DEPLOYMENT_BLOCK_CLAIMBOND=41680286

# Optional: "debug" | "info" | "warn" | "error".
PONDER_LOG_LEVEL=info
