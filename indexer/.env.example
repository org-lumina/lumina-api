# Sprint J — Ponder indexer env vars.
# Copy to .env in this directory for local development. In Railway, set
# these as service-level env vars on the same lumina-api service so both
# the API and the indexer read from the same source of truth.

# RPC endpoints (priority: QuickNode > Alchemy > public). The indexer's
# eth_getLogs traffic is heavy — QuickNode's archive endpoints are
# preferred for catching up from a deep startBlock.
RPC_URL_QUICKNODE=https://YOUR-ENDPOINT.base-sepolia.quiknode.pro/YOUR_KEY/
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Database — Ponder uses Postgres. In Railway, attach a Postgres plugin
# and copy DATABASE_URL here. Do NOT reuse the SQLite at api/lumina.db.
DATABASE_URL=postgres://user:pass@host:port/lumina_indexer

# Contract addresses (mirror lumina-api). Defaults below match the Sprint H
# manifest snapshot — only override when redeploying.
COVER_ROUTER=0xFA6d57CA87a26F08d68f2123e86990E2fD70B7AE
CLAIM_BOND=0xde85056F155d3F18e559Fa63d5861ab3D1318cF0
BOND_VAULT=0x9EfdD63B13543B30B49b2b423903233220B3726c
TWAP_BURNER=0xc838BEDE6BE624f6b7b69be71b7587ce51186D75
FOUNDER_VESTING=0xa3e7685E21A141930F63432E927D679fD3FDE876

# Indexer start block — set to the block where ClaimBond was deployed so
# we don't scan from genesis. Look it up at:
#   https://sepolia.basescan.org/address/0xde85056F155d3F18e559Fa63d5861ab3D1318cF0
#   tab "Contract" → "Contract Creator: <hash> at txn <hash>" → click txn → see Block.
DEPLOYMENT_BLOCK_CLAIMBOND=

# Optional log level: "debug" | "info" | "warn" | "error".
PONDER_LOG_LEVEL=info
