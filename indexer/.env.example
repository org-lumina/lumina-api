# LUMINA Ponder indexer — env vars.
# Copy to indexer/.env for local dev. In Railway, set these as SERVICE-level
# env vars on the same lumina-api service so the API and indexer share one
# source of truth. Code never hardcodes addresses — these env vars are required.

# ── RPC (priority: QuickNode > Alchemy > public) ──
# The indexer's eth_getLogs backfill is heavy; an archive endpoint is strongly
# preferred. Public mainnet.base.org works but is slow/rate-limited for backfill.
RPC_URL_QUICKNODE=https://YOUR-ENDPOINT.base-mainnet.quiknode.pro/YOUR_KEY/
RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Database ── Ponder needs Postgres. In Railway: add a Postgres plugin and
# paste its DATABASE_URL here (NEVER commit a real one). Do NOT reuse the
# API's SQLite (api/lumina.db).
DATABASE_URL=postgres://user:pass@host:port/lumina_indexer

# ── Canonical V5.4 contract addresses (Base mainnet, 8453, deployed 2026-05-28) ──
# These are PUBLIC on-chain addresses; safe as documented defaults. Cross-check
# against /c/tmp/mainnet-deploy/MANIFEST-MAINNET.md.
COVER_ROUTER=0x7A49B31DC3540E037cdCEb95765eD46f6a515aa2
CLAIM_BOND=0x8203435Bc108FaBE1beB1fe40F66a7C8B42529F1
BOND_VAULT=0x1C50d05eEF138aAa9df22a001db4a75343a604E4
TWAP_BURNER=0x99AA64806b680AbEB073Eb2171bda138a5D52b58
MARKETPLACE=0xfB3ec1B507DE8a7dB50691a26f872360F0EF71AB
FOUNDER_VESTING=0xBC5C561a13BdC886A08F4bB901E198C1Fbd2803A

# ── Indexer start block ── V5.4 mainnet genesis = DeployLuminaV5Mainnet
# broadcast block on 2026-05-28. Avoids scanning from chain genesis. Override
# only on a fresh redeploy.
DEPLOYMENT_BLOCK_CLAIMBOND=46608336

# Optional: "debug" | "info" | "warn" | "error".
PONDER_LOG_LEVEL=info
