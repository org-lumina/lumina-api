# ────────────────────────────────────────────────────────────────
# Lumina API — Environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ────────────────────────────────────────────────────────────────
# V5.4 LIVE on Base mainnet (chain 8453) since 2026-05-28. All addresses
# below are mainnet defaults; override per environment.

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Network — Base mainnet
RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_ID=8453

# [Sprint F] Optional fallback RPCs for redundancy. When set, ethers wraps
# RPC_URL + these into a FallbackProvider (priority: Alchemy > QuickNode >
# public). https://mainnet.base.org is the implicit last-resort if
# RPC_URL_PUBLIC is unset. Leaving these blank degrades to single-RPC mode.
RPC_URL_QUICKNODE=https://YOUR-ENDPOINT.base-mainnet.quiknode.pro/YOUR_KEY/
RPC_URL_PUBLIC=https://mainnet.base.org

# Relayer (signs txs on behalf of agents). MUST be funded with Base ETH.
RELAYER_PRIVATE_KEY=0xPLACEHOLDER_REPLACE_BEFORE_RUN

# Admin token for /api/v1/keys/generate. Long random string.
ADMIN_TOKEN=PLACEHOLDER_long_random_secret_at_least_32_chars

# ────────────────────────────────────────────────────────────────
# Contract addresses — V5.4 Base mainnet (deployed 2026-05-28)
# ────────────────────────────────────────────────────────────────
LUMINA_TOKEN=0xa35766202444d1d3D6d09Cf687B29D3C2632223C
CLAIM_BOND=0x8203435Bc108FaBE1beB1fe40F66a7C8B42529F1
BOND_VAULT=0x1C50d05eEF138aAa9df22a001db4a75343a604E4
POLICY_MANAGER=0x8c20dfE07a5679b8DE8376361Bc9f63eD081C268
COVER_ROUTER=0x7A49B31DC3540E037cdCEb95765eD46f6a515aa2
MARKETPLACE=0xfB3ec1B507DE8a7dB50691a26f872360F0EF71AB
USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Auxiliary contracts (not required by core API, exposed via /health for SDK)
CAPACITY_ORACLE=0x4dFbb04b60d41A6B5693c7181d0a7Cc43d82e8E3
SOLVENCY_ORACLE=0x1F52f9AD24Aab2f70cb8837F37FF463BC1A795FD
ADAPTIVE_FEE_DISTRIBUTOR=0xafD0928BFf5488D978F16b907e4Be84B15B95AB2
TWAP_BURNER=0x99AA64806b680AbEB073Eb2171bda138a5D52b58
SHIELD_KEEPER=0x8F43fB0C7F7F3A26D9631c1f430b08CF9C6879c3
CEX_LIQUIDITY_RESERVE=0x5f860688Bf6B7faf70c9447083AD74afdb839035
MAINTENANCE_RESERVE=0xFB294813e57b464ca5Db34ec45Dc9bAfab4EDEe6
FOUNDER_VESTING=0xBC5C561a13BdC886A08F4bB901E198C1Fbd2803A
TREASURY_VESTING=0x745f4a9b77b5cCaF4B418ee1e5e1865Bfe088B75
BUYBACK_ENGINE=0x558F1675c10650A027e68BE33F8C5F290d8Ea307
AERODROME_ADAPTER=0xc91D4110e9cF2Aad8BCfe7e3B3496BF5f3B4a4E4
UNISWAP_V3_ADAPTER=0x9ABe1C96C4Ac29c50f1BEE0CF9C10B95f3345059

# Block at which ClaimBond contract was deployed (mainnet broadcast 2026-05-28).
# Wallet/policy scan ranges floor to this so we never scan pre-deploy blocks.
DEPLOYMENT_BLOCK_CLAIMBOND=46608336

# Database
DB_PATH=./lumina.db

# Rate limit defaults (overridable per tier in DB)
RATE_LIMIT_FREE_RPM=10
RATE_LIMIT_PAID_RPM=100

# ────────────────────────────────────────────────────────────────
# Oracle V2 signer (EIP-712) — Base mainnet 8453
# ────────────────────────────────────────────────────────────────
LUMINA_ORACLE_V2=0x191Be3f976CC7471aE2cc4001e92611BA0De1bef
# Signer key whose ADDRESS matches LuminaOracleV2.oracleKey() on-chain.
# This is the ONLY key allowed to sign EIP-712 PriceProofs accepted by the oracle.
ORACLE_PRIVATE_KEY=0xPLACEHOLDER_REPLACE_BEFORE_RUN

# Chainlink AggregatorV3 feeds — Base mainnet (canonical Chainlink data feeds).
BTC_PRICE_FEED=0x64c911996D3c6aC71f9b455B1E8E7266BcbD848F
ETH_PRICE_FEED=0x71041dddad3595F9CEd3DcCFBe3D1F4b0a16Bb70

# ────────────────────────────────────────────────────────────────
# Sandbox / "Try It" widget (optional) — TESTNET-ONLY (Base Sepolia)
# ────────────────────────────────────────────────────────────────
# The /sandbox/* path always targets Base Sepolia with mock USDC, regardless
# of the CHAIN_ID setting above. It exists so AI agents can exercise the full
# purchase → trigger → bond flow without real funds. When SANDBOX_WALLET is
# unset, /sandbox/* responds 503 sandbox_disabled.
# SANDBOX_WALLET=0x0000000000000000000000000000000000000000
# Per-purchase coverage cap in USDC base units (6-dec). Default $1.
# SANDBOX_COVER_USDC=1000000
