# ────────────────────────────────────────────────────────────────
# Lumina API — Environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ────────────────────────────────────────────────────────────────
# SPRINT_Z2: all addresses cleared pre-redeploy. Populate after new deployment.

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Network — Base Sepolia
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_ID=84532

# [Sprint F] Optional fallback RPCs for redundancy. When set, ethers wraps
# RPC_URL + these into a FallbackProvider (priority: Alchemy > QuickNode >
# public). https://sepolia.base.org is the implicit last-resort if
# RPC_URL_PUBLIC is unset. Leaving these blank degrades to single-RPC mode.
RPC_URL_QUICKNODE=https://YOUR-ENDPOINT.base-sepolia.quiknode.pro/YOUR_KEY/
RPC_URL_PUBLIC=https://sepolia.base.org

# Relayer (signs txs on behalf of agents). MUST be funded with Sepolia ETH.
RELAYER_PRIVATE_KEY=0xPLACEHOLDER_REPLACE_BEFORE_RUN

# Admin token for /api/v1/keys/generate. Long random string.
ADMIN_TOKEN=PLACEHOLDER_long_random_secret_at_least_32_chars

# Contract addresses (Base Sepolia V5.1 — 2026-04-27 deploy)
LUMINA_TOKEN=0x17db45491561F7538e4E14449DCC34799758465D
CLAIM_BOND=0x5304f6732a51995651f1B666525CFeC5Af74A541
BOND_VAULT=
POLICY_MANAGER=0x04f94Bc24aAA87aDFA643EE1e55a35C683f30804
COVER_ROUTER=0x60447F880Fad94fe1E17DBe9A0Cb39923bC9f316
MARKETPLACE=0x863A7fB4A676106db4b03449b01AC5615c6C9D51
USDC=0x63D340AE7229BB464bC801f225651341ebcD3693

# Block at which ClaimBond contract was deployed; if unset, scanner falls back to latest-500k
DEPLOYMENT_BLOCK_CLAIMBOND=

# Database
DB_PATH=./lumina.db

# Rate limit defaults (overridable per tier in DB)
RATE_LIMIT_FREE_RPM=10
RATE_LIMIT_PAID_RPM=100

# ────────────────────────────────────────────────────────────────
# Oracle V2 signer (EIP-712) — Base Sepolia 84532
# ────────────────────────────────────────────────────────────────
LUMINA_ORACLE_V2=
# Signer key whose ADDRESS matches LuminaOracleV2.oracleKey() on-chain.
# This is the ONLY key allowed to sign EIP-712 PriceProofs accepted by the oracle.
ORACLE_PRIVATE_KEY=0xPLACEHOLDER_REPLACE_BEFORE_RUN

# Chainlink-compatible AggregatorV3 feeds (Base Sepolia mocks for V5.1).
# Fallback to V5.1 mocks if Chainlink testnet feeds are not exposed for Base Sepolia.
BTC_PRICE_FEED=0x2aDC8718F0b7Efb18a07aBc7595F1364730bb99E
ETH_PRICE_FEED=0x2a370A7dAE38aF7EECA20C9438Bd5154889cdc5e

# ────────────────────────────────────────────────────────────────
# Sandbox / "Try It" widget (optional)
# ────────────────────────────────────────────────────────────────
# When SANDBOX_WALLET is unset, /sandbox/* responds 503 sandbox_disabled.
# The wallet is the buyer-of-record on every /sandbox/try purchase. Fund it
# externally (cron tops it up with mUSDC); the API merely consumes from it.
# SANDBOX_WALLET=0x0000000000000000000000000000000000000000
# Per-purchase coverage cap in USDC base units (6-dec). Default $1.
# SANDBOX_COVER_USDC=1000000
